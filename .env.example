# Environment Variables for Lex Iuridicus
# Copiar a .env.local en producción y llenar con valores reales

# Node Environment
NODE_ENV=production

# Port (Default: 3000)
PORT=3000

# Base URL
NEXT_PUBLIC_BASE_URL=https://darkslateblue-sheep-899946.hostingersite.com
NEXT_PUBLIC_SITE_URL=https://darkslateblue-sheep-899946.hostingersite.com

# Google Analytics (opcional)
NEXT_PUBLIC_GA_ID=G_XXXXXXXXXX

# Email Configuration (si implementas backend)
